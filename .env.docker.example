# ==============================================================
# Dolibarr Modern Frontend — environment for Docker
# Copy this file to .env.docker and fill the values marked REQUIRED.
# ==============================================================

# --- Required: Dolibarr backend connection ---------------------
DOLIBARR_BASE_URL=https://your-dolibarr-domain.com/api/index.php
DOLIBARR_API_KEY=your-dolibarr-admin-api-key
DOLIBARR_VERIFY_SSL=true

# --- App basics ------------------------------------------------
APP_NAME="Dolibarr Modern Frontend"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_TIMEZONE=UTC
APP_LOCALE=es
APP_FALLBACK_LOCALE=en

# --- Logging ---------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- Storage / drivers (defaults are fine for single-container) -
DB_CONNECTION=sqlite
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Cookies / sessions ----------------------------------------
# For local HTTP: keep these defaults. Behind HTTPS, set:
#   SESSION_SAME_SITE=lax     (or "none" if you embed in another origin)
#   SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

# --- CORS (only relevant if you call the API from another origin)
CORS_ALLOWED_ORIGINS=http://localhost:8080
CORS_SUPPORTS_CREDENTIALS=true

# --- Docker / compose overrides (optional) ---------------------
# APP_PORT=8080
# IMAGE_NAME=cehojac/dolibarr-modern-frontend
# IMAGE_TAG=latest
